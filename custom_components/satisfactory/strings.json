{
  "config": {
    "step": {
      "user": {
        "data": {
          "host": "[%key:common::config_flow::data::host%]",
          "port": "[%key:common::config_flow::data::port%]",
          "password": "[%key:common::config_flow::data::password%]",
          "skip_ssl_verification": "Disable SSL verification"
        }
      }
    },
    "error": {
      "cannot_connect": "[%key:common::config_flow::error::cannot_connect%]",
      "invalid_auth": "[%key:common::config_flow::error::invalid_auth%]",
      "unknown": "[%key:common::config_flow::error::unknown%]"
    },
    "abort": {
      "already_configured": "[%key:common::config_flow::abort::already_configured_device%]"
    }
  },
  "entity": {
    "sensor": {
      "num_connected_players": {"name": "Connected players"},
      "player_limit": {"name": "Player limit"},
      "tech_tier": {"name": "Tech tier"},
      "average_tick_rate": {"name": "Average tick rate"},
      "total_game_duration": {"name": "Total game duration"},
      "active_session_name": {"name": "Active session"},
      "game_phase": {"name": "Game phase"},
      "server_health": {"name": "Server health"}
    }
  }
}
